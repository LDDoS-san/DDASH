const map = L.map('map').setView([35.02,135.76],10);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  attribution:'&copy; OpenStreetMap'
}).addTo(map);

function getColor(pop){
  if(pop > 5000) return "#800026";
  if(pop > 3000) return "#BD0026";
  if(pop > 1000) return "#E31A1C";
  if(pop > 500) return "#FC4E2A";
  return "#FFEDA0";
}

L.geoJSON(meshData,{
  style: function(feature){
    const pop = feature.properties.population; // ←列名要確認
    return {
      fillColor: getColor(pop),
      weight: 0.3,
      color: "#555",
      fillOpacity: 0.6
    };
  },
  onEachFeature: function(feature,layer){
    layer.on("click",function(){
      const p = feature.properties;
      layer.bindPopup(
        "人口: " + p.population + "人"
      ).openPopup();
    });
  }
}).addTo(map);

